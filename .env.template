# CUET Platform — Vite Environment Variables
# Rename to .env.local for local dev | Set on hosting platform for prod
# NEVER commit .env.local to git

# ── Firebase ──────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Razorpay (PUBLIC key only) ─────────────────────────────────────
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx

# ── GA4 ───────────────────────────────────────────────────────────
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Cloud Functions base URL ───────────────────────────────────────
# Deployed region: us-central1 (do NOT use asia-south2 — functions are in us-central1)
# Leave EMPTY for local dev (falls back to direct API — dev only)
VITE_CLOUD_FUNCTION_BASE=

# Admin key — set in Netlify env vars
VITE_ADMIN_KEY=your-admin-key-here
