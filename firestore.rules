rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin check via Firebase custom claim — no PII in rules
    // Set the admin claim once using the grantAdminClaim Cloud Function
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Users: read own doc; admin can read all
    match /users/{uid} {
      allow read:   if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid
                    && !request.resource.data.keys().hasAny(['unlocked']);
      // Regular users: can update own doc but cannot touch protected fields
      allow update: if request.auth != null && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['unlocked', 'paymentId', 'unlockedAt', 'graceReturns', 'testsUsed']);
      // Admin: can update any user doc (for grantAccess / revokeAccess / resetLimit from dashboard)
      allow update: if isAdmin();
    }

    // Tests: create own, read own; admin can read all
    match /tests/{testId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read:   if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // Payments: admin read only (writes via admin SDK only)
    match /payments/{paymentId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Question cache: admin read only
    match /questionCache/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Presence: user writes own heartbeat; admin reads all
    match /presence/{uid} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read:  if isAdmin();
    }

    // Feedback: any logged-in user can submit; admin can read all
    match /feedback/{docId} {
      allow create: if request.auth != null;
      allow read:   if isAdmin();
    }

    // Ratings: user can create/update own rating; admin can read all
    match /ratings/{docId} {
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow read:   if isAdmin();
    }

    // Health checks: admin read only (writes via admin SDK only)
    match /healthChecks/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Health auto-fix audit log: admin read only (writes via admin SDK only)
    match /healthAutoFix/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // CUET exam intelligence: admin read only (writes via admin SDK only)
    match /cuetIntelligence/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Cache control (fill lock): admin read only (writes via admin SDK only)
    match /cacheControl/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }
  }
}
