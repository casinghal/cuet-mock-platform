# ============================================================
# VANTIQ CUET PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env for local dev (never commit .env)
# Set all these in Netlify → Site settings → Environment variables
# ============================================================

# Firebase (client-safe — public config)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Razorpay (Key ID is client-safe — Secret goes to Firebase CF config ONLY)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# GA4 (set after creating GA4 property)
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Cloud Functions base URL (set after CF deploy)
# Format: https://asia-south2-YOUR_PROJECT_ID.cloudfunctions.net
VITE_CLOUD_FUNCTION_BASE=https://asia-south2-your-project-id.cloudfunctions.net
